# ============================================================
# CHASKI AI 2.0 — Variables de entorno
# Copia este archivo como .env y configura tus valores
# ============================================================

# Servidor
PORT=3000
NODE_ENV=development

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chaski ai2
DB_USER=postgres
DB_PASSWORD=tu_contraseña_aqui

# JWT
JWT_SECRET=chaski_ai_super_secret_key_2050_tipcar
JWT_EXPIRES_IN=24h

# CORS - origen del frontend
FRONTEND_URL=http://localhost:5500

# Velocidad máxima permitida (km/h)
MAX_SPEED_LIMIT=90
SPEED_ALERT_DURATION_MINUTES=4
