# ============================================================
# CHASKI AI 2.0 — Variables de entorno
# ============================================================
# 1. Copia este archivo: cp .env.example .env
# 2. Rellena cada valor con tus datos reales
# 3. NUNCA subas el archivo .env al repositorio
# ============================================================


# ── Servidor ─────────────────────────────────────────────────
# Puerto en el que corre el backend Express
PORT=3005

# Entorno de ejecución: development | production
NODE_ENV=development


# ── Base de datos PostgreSQL ──────────────────────────────────
# Crea la BD con: CREATE DATABASE chaski_ai2;
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chaski_ai2
DB_USER=postgres
DB_PASSWORD=123456


# ── JWT — Autenticación ───────────────────────────────────────
# CRÍTICO: usa una cadena aleatoria larga y única.
# Genera una con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=reemplaza_con_cadena_aleatoria_minimo_32_caracteres

# Duración del access token. Opciones: 15m | 1h | 24h
# Para mayor seguridad en producción usa 15m (el frontend hace refresh automático)
JWT_EXPIRES_IN=24h


# ── CORS ─────────────────────────────────────────────────────
# Orígenes del frontend autorizados, separados por coma, sin barra al final.
# En desarrollo: los puertos de Live Server y del propio backend
# En producción: solo el dominio real del frontend
ALLOWED_ORIGINS=http://localhost:3005,http://localhost:5500
# Producción: ALLOWED_ORIGINS=https://chaski-ai.tudominio.com


# ── GPS — Integración Traccar ─────────────────────────────────
# URL base de tu instancia Traccar (sin /api al final)
TRACCAR_URL=http://tu-servidor-traccar:8082

# Credenciales de administrador de Traccar
TRACCAR_USER=admin@tuempresa.pe
TRACCAR_PASS=tu_password_traccar

# Nota: el servidor TCP para Teltonika FMC130 escucha en el puerto 2223.
# No requiere variable de entorno — está hardcodeado en backend/gps-server.js


# ── IA — Anthropic Claude ─────────────────────────────────────
# Obtén tu clave en: https://console.anthropic.com
# El asistente IA no funcionará sin esta clave (devuelve 503)
ANTHROPIC_API_KEY=your_anthropic_api_key_here


# ── Alertas de velocidad ──────────────────────────────────────
# Velocidad máxima permitida en km/h. Se registra alerta si se supera.
MAX_SPEED_LIMIT=90

# Minutos de cooldown entre alertas del mismo vehículo (evita spam de alertas)
SPEED_ALERT_DURATION_MINUTES=4


# ── Rate limiting (valores de referencia — hardcodeados en rateLimiter.js) ──
# Los siguientes valores son informativos. Para cambiarlos edita:
# backend/middleware/rateLimiter.js
#
# loginLimiter:        10 intentos / 15 minutos por IP
# apiLimiter:         300 peticiones / minuto
# aiLimiter:           30 consultas / minuto al asistente IA
